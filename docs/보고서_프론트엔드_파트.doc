<title>독거노인 안전 모니터링 시스템 - 프론트엔드 파트 보고서</title>
<style>
  body { font-family: "맑은 고딕", "Malgun Gothic", sans-serif; font-size: 11pt; line-height: 1.7; color: #000; margin: 30px 40px; }
  h1 { font-size: 16pt; border-bottom: 2px solid #333; padding-bottom: 6px; margin-top: 36px; }
  h2 { font-size: 13pt; margin-top: 28px; border-left: 5px solid #2b6cb0; padding-left: 8px; }
  h3 { font-size: 12pt; margin-top: 20px; }
  p { margin: 6px 0; }
  ul, ol { margin: 6px 0 6px 0; padding-left: 22px; }
  li { margin: 3px 0; }

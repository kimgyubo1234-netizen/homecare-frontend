  th { background: #eef2f7; text-align: center; }
  td.c { text-align: center; }
  .fig { font-family: "D2Coding", "Consolas", monospace; font-size: 9pt; white-space: pre; background: #f7f8fa; border: 1px solid #ccc; padding: 12px; line-height: 1.35; overflow-x: auto; }
